# Example environment variables for Wordpress-PostToAlbum-Script
# Copy this file to .env and update values as needed.

# WordPress: all three are required by run, apply-plan, and stats.
WORDPRESS_BASE_URL=https://your-site.example
WORDPRESS_USERNAME=api-user
WORDPRESS_APP_PASSWORD=application-password

# Providers: run requires all three; fuzzy requires only the Spotify pair.
LASTFM_API_KEY=your-lastfm-key
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...